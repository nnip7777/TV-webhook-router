# Server
WEBHOOK_ROUTER_ADMIN_PASSWORD=change_me
WEBHOOK_ROUTER_HOST=127.0.0.1
WEBHOOK_ROUTER_PORT=8787
WEBHOOK_ROUTER_PUBLIC_BASE_URL=http://127.0.0.1:8787
WEBHOOK_ROUTER_BACKUP_DIR=./backups
WEBHOOK_ROUTER_BACKUP_KEEP_COUNT=20
WEBHOOK_ROUTER_ROOT=.
WEBHOOK_ROUTER_CONFIG_PATH=./config/routing.json
WEBHOOK_ROUTER_OBSERVED_SIGNALS_PATH=./config/observed_signals.json
WEBHOOK_ROUTER_INSTRUMENTS_PATH=./config/instruments.json
WEBHOOK_ROUTER_LOG_PATH=./logs/webhooks.jsonl
WEBHOOK_ROUTER_JOURNAL_LOG_PATH=./logs/journal
WEBHOOK_ROUTER_JOURNAL_KEEP_WEEKS=12

# External helper / legacy executor (optional, needed for current Alor path)
WEBHOOK_ROUTER_SMART_EXECUTOR_PATH=external/smart_order_executor.py

# Bybit
BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET_KEY=your_bybit_secret_key
BYBIT_LIVE_BASE_URL=https://api.bybit.com
BYBIT_TESTNET_BASE_URL=https://api-testnet.bybit.com
BYBIT_BIND_INTERFACE=

# BingX Perpetual
BINGX_API_KEY=your_bingx_api_key
BINGX_SECRET_KEY=your_bingx_secret_key
BINGX_LIVE_BASE_URL=https://open-api.bingx.com
BINGX_LIVE_FALLBACK_BASE_URL=https://open-api.bingx.pro
BINGX_TESTNET_BASE_URL=https://open-api-vst.bingx.com
BINGX_TESTNET_FALLBACK_BASE_URL=https://open-api-vst.bingx.pro
BINGX_BIND_INTERFACE=
BINGX_SOURCE_KEY=BX-AI-SKILL
BINGX_RECV_WINDOW=5000

# Alor
ALOR_CONFIG_PATH=broker/alor/config.json
ALOR_OAUTH_URL=https://oauth.alor.ru
ALOR_API_BASE_URL=https://api.alor.ru
ALOR_ALLOW_MARGIN=true

# Finam
FINAM_SECRET_PATH=broker/finam/token.secret
FINAM_ACCOUNT_ID=1915526

# Schwab
SCHWAB_CONFIG_PATH=broker/schwab/config.json
